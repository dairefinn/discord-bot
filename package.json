{
	"name": "discord-bot",
	"version": "1.0.0",
	"description": "Discord bot running on Cloudflare Workers",
	"scripts": {
		"dev": "npx wrangler dev",
		"deploy": "npx wrangler deploy",
		"lint": "yarn check:prettier && yarn check:eslint && yarn check:tsc",
		"check:prettier": "prettier --check --no-error-on-unmatched-pattern '*.{json,js}' 'src/**/*.{js,ts}' 'test/**/*.{js,ts}'",
		"check:eslint": "eslint --max-warnings=0 src",
		"check:tsc": "tsc --noEmit",
		"fix:prettier": "prettier --write --no-error-on-unmatched-pattern '*.{json,js}' 'src/**/*.{js,ts}' 'test/**/*.{js,ts}'",
		"test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
		"register": "tsx src/register-commands.ts"
	},
	"author": "author",
	"license": "MIT OR Apache-2.0",
	"eslintConfig": {
		"root": true,
		"extends": [
			"typescript",
			"prettier"
		]
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250517.0",
		"@types/node": "^25.3.3",
		"@typescript-eslint/eslint-plugin": "^5.32.0",
		"@typescript-eslint/parser": "^5.32.0",
		"eslint": "^8.21.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-config-typescript": "^3.0.0",
		"miniflare": "^4.20250508.2",
		"prettier": "^2.7.1",
		"tsx": "^4.21.0",
		"typescript": "^4.7.4",
		"wrangler": "^4.15.2"
	},
	"dependencies": {
		"discord-interactions": "^4.4.0"
	}
}
